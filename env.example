# Copy this file to .env and fill in real values. Never commit .env to version control.
# Locally, both app.py and the sync read these from .env. In the cloud they are
# set as Vercel Environment Variables (for the app) and GitHub Actions Secrets
# (for the sync) instead of living in a file.

SMARTSHEET_TOKEN=your_smartsheet_api_token_here
SMARTSHEET_REPORT_ID=5778567599181700

# Deputy uses OAuth 2.0. Run deputy_oauth_setup.py ONCE first, manually, to
# create deputy_token_store.json. On first sync that token is copied into the
# Supabase database (table: deputy_tokens) and auto-refreshed there from then on,
# so the cloud sync has no local file to depend on.
DEPUTY_TOKEN_STORE=deputy_token_store.json
DEPUTY_LOOKAHEAD_DAYS=14

# Only shifts rostered at these Deputy Locations (Operational Units) are pulled
# in — this is how we scope the dashboard to BOH staff only. Comma-separated,
# and must match the names as they appear in Deputy (dash characters and all).
DEPUTY_BOH_LOCATION_NAMES=Venue Tech – Level One,Venue Tech – Level Two,Venue Tech – Level Three,Audio Tech – Level One,Audio Tech – Level Two,Audio Tech – Level Three,Lighting Tech – Level One,Lighting Tech – Level Two,Lighting Tech – Level Three,Vision Tech – Level One,Vision Tech – Level Two,Vision Tech – Level Three,Rigger – Level One,Rigger – Level Two,Rigger – Level Three,Senior Technician – Production

# Shared cloud database (Supabase Postgres). Used by both app.py (the web
# server) and sync_precinct_dashboard.py (the scheduled sync). For the web app
# on Vercel, use Supabase's "Transaction" pooler connection string (port 6543).
DATABASE_URL=postgresql://postgres:password@host:6543/postgres
