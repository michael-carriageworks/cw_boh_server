# Copy this file to .env and fill in real values. Never commit .env to version control.

SMARTSHEET_TOKEN=your_smartsheet_api_token_here
SMARTSHEET_REPORT_ID=5778567599181700

# Deputy uses OAuth 2.0. Run deputy_oauth_setup.py ONCE first, manually, to
# create deputy_token_store.json — the sync script reads and auto-refreshes
# that file from then on. You do NOT put a Deputy token here directly.
DEPUTY_TOKEN_STORE=deputy_token_store.json
DEPUTY_LOOKAHEAD_DAYS=14

# Only shifts rostered at this Deputy Location (Operational Unit) are pulled
# in — this is how we scope the dashboard to BOH staff only. Must match the
# exact name as it appears in Deputy's location dropdown.
DEPUTY_BOH_LOCATION_NAME=CW-BOH

# Shared database — used by both app.py (the web server) and
# sync_precinct_dashboard.py (the scheduled sync job). Both must point to
# the exact same file.
DB_PATH=boh_dashboard.db
